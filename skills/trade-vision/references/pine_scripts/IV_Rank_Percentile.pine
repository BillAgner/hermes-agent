//@version=5
// =============================================================================
//  IV_Rank_Percentile.pine  —  Trade Vision CC advisor
//  ---------------------------------------------------------------------------
//  Realized-volatility based IV rank & percentile, computed from log returns.
//
//      RV_t   = sqrt(tradingDays / window) * stdev(log_returns, window)
//      RV_Hi  = rolling max of RV over the last 252 bars (52-week high)
//      RV_Lo  = rolling min of RV over the last 252 bars (52-week low)
//
//      IV rank       = (RV - RV_Lo) / (RV_Hi - RV_Lo) * 100
//      IV percentile = % of past RV values <= current RV
//
//  The script is called "IV rank" because CC advisors use IV rank as the
//  primary selling-condition filter. We compute it from realized vol because
//  TradingView has no native option-chain IV feed; RV is the best proxy.
//
//  Outputs:
//      - Two lines (rank 0-100, percentile 0-100) in a separate pane
//      - Threshold lines at 25 / 50 / 75
//      - Background tint: green when rank<25 (cheap premium), red when >75
//      - Top-right table: RV, rank, percentile, regime label, CC advice
//
//  Self-check marker: [OK] if it compiles, [FAIL] otherwise.
// =============================================================================
indicator("IV Rank / Percentile (RV-based, Trade Vision)",
     shorttitle = "IV Rank",
     overlay    = false,
     precision  = 2)

// -----------------------------------------------------------------------------
//  Helper: percentile of the current value within its rolling window.
//      Counts how many of the last `len` values are <= the current value,
//      returns (count / len) * 100.
// -----------------------------------------------------------------------------
rv_rank_pct(src, len) =>
    cnt = 0.0
    for i = 0 to len - 1
        if src[i] <= src
            cnt += 1.0
    (cnt / len) * 100.0

// -----------------------------------------------------------------------------
//  Inputs
// -----------------------------------------------------------------------------
i_rvLen    = input.int(20,    "RV window (bars)",     minval=5,   maxval=60)
i_lookback = input.int(252,  "Lookback bars (52w)",   minval=60,  maxval=500)
i_ann      = input.float(252.0, "Trading days / yr",  minval=200.0, maxval=365.0, step=1.0)

// Threshold inputs (CC advisor defaults — sell when IV rank < 25)
i_thrHi    = input.float(75.0, "High regime threshold", minval=50.0, maxval=95.0, step=5.0)
i_thrLo    = input.float(25.0, "Low regime threshold",  minval=5.0,  maxval=50.0, step=5.0)

// -----------------------------------------------------------------------------
//  Realized volatility (annualized)
// -----------------------------------------------------------------------------
logRet = math.log(close / close[1])
sigma  = ta.stdev(logRet, i_rvLen)
rv     = sigma * math.sqrt(i_ann / i_rvLen) * 100.0   // express as %

// 52-week (or `i_lookback`) range
rvHi = ta.highest(rv, i_lookback)
rvLo = ta.lowest(rv,  i_lookback)

// IV rank: where is current RV in the recent range?
range_ = rvHi - rvLo
ivRank = range_ > 0 ? ((rv - rvLo) / range_) * 100.0 : 50.0
ivRank := math.max(0.0, math.min(100.0, ivRank))

// IV percentile: what % of past RV values are <= current RV
ivPct = rv_rank_pct(rv, i_lookback)
ivPct := math.max(0.0, math.min(100.0, ivPct))

// -----------------------------------------------------------------------------
//  Regime classification
// -----------------------------------------------------------------------------
regime = ivRank >= i_thrHi ? "HIGH (premium rich)"
       : ivRank <= i_thrLo ? "LOW  (premium cheap)"
       :                     "MID  (neutral)"

regimeColor = ivRank >= i_thrHi ? color.red :
              ivRank <= i_thrLo ? color.green : color.gray

// CC advisor recommendation hint
recommend = ivRank <= i_thrLo ? "SELL calls" :
            ivRank >= i_thrHi ? "AVOID  selling" :
                                "OPTIONAL"

// -----------------------------------------------------------------------------
//  Plots
// -----------------------------------------------------------------------------
plot(ivRank, "IV Rank",       color = color.new(color.blue,   0), linewidth = 2)
plot(ivPct,  "IV Percentile", color = color.new(color.purple, 0), linewidth = 1)

// Threshold lines
hline(50.0,   "Midline", color = color.gray,  linestyle = hline.style_dashed)
hline(i_thrHi, "High",    color = color.red,   linestyle = hline.style_dotted)
hline(i_thrLo, "Low",     color = color.green, linestyle = hline.style_dotted)

// Background tint by regime
bgcolor(ivRank >= i_thrHi ? color.new(color.red,   90) :
         ivRank <= i_thrLo ? color.new(color.green, 90) : na,
         title = "Regime background")

// -----------------------------------------------------------------------------
//  Display table
// -----------------------------------------------------------------------------
var tbl = table.new(position.top_right, 2, 7,
     bgcolor      = color.new(color.black, 20),
     border_color = color.gray,
     border_width = 1,
     frame_color  = color.gray,
     frame_width  = 1)

if barstate.islast
    table.cell(tbl, 0, 0, "IV Rank (RV-based)", text_color=color.white, text_size=size.small, bgcolor=color.new(color.blue, 40))
    table.cell(tbl, 1, 0, "",                    bgcolor=color.new(color.blue, 40))

    table.cell(tbl, 0, 1, "Realized vol (annualized)",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 1, str.tostring(rv, "#.##") + "%",
         text_color = color.white, text_size = size.small)

    table.cell(tbl, 0, 2, "52w RV high / low",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 2, str.tostring(rvHi, "#.##") + "% / " + str.tostring(rvLo, "#.##") + "%",
         text_color = color.white, text_size = size.small)

    table.cell(tbl, 0, 3, "IV rank",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 3, str.tostring(ivRank, "#.##"),
         text_color = ivRank >= i_thrHi ? color.red :
                      ivRank <= i_thrLo ? color.green : color.white,
         text_size  = size.normal)

    table.cell(tbl, 0, 4, "IV percentile",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 4, str.tostring(ivPct, "#.##"),
         text_color = color.aqua, text_size = size.small)

    table.cell(tbl, 0, 5, "Regime",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 5, regime,
         text_color = color.white, text_size = size.small, bgcolor = regimeColor)

    table.cell(tbl, 0, 6, "CC advice",
         text_color = color.white, text_size = size.small)
    table.cell(tbl, 1, 6, recommend,
         text_color = ivRank <= i_thrLo ? color.lime :
                      ivRank >= i_thrHi ? color.red  : color.yellow,
         text_size  = size.small)

// -----------------------------------------------------------------------------
//  Self-check
// -----------------------------------------------------------------------------
// [OK] IV_Rank_Percentile.pine — compiles cleanly. Pine v5.
//      Notes:
//      - Both IV rank and IV percentile computed from REALIZED vol because
//        Pine has no live options-chain IV feed. Replace with `request.security()`
//        pulling CBOE IV data if available on the symbol.
//      - `rv_rank_pct` runs on every bar; loop is O(252) per bar, cheap.
//      - For tickers with < `i_lookback` history the percentile will be biased
//        upward; the rank still works because it only needs 2 points in window.
//      - Regime thresholds (25/75) match standard CC advisor defaults; tweak
//        via the inputs panel.
//      - ivRank re-assignment via `:=` ensures clamping after the conditional.
//      - The `var` table is created once, populated on the last bar only.