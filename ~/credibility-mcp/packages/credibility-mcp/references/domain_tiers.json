  "suffix_rules": {
    ".gov": "gov_official",
    ".mil": "gov_official",
    ".europa.eu": "gov_official"
  },
  "content_farm_signals": {
    "url_patterns": [
      "best-",
      "top-10-",
      "top-",
      "/review/",
      "/reviews/",
      "/buying-guide/",
      "/affiliate/",
      "?ref=",
      "?utm_"
    ],
    "domain_substrings": [
      "bestof",
      "top10",
      "reviewsite",
      "dealsite",
      "coupons",
      "freekindle",
      "ai-generated"
    ],
    "score_penalty": 0.30
  },
  "recency_windows": {
    "primary_data": {
      "fresh_days": 7,
      "stale_days": 90
    },
    "mainstream_press": {
      "fresh_days": 7,
      "stale_days": 60
    },
    "peer_reviewed": {
      "fresh_days": 365,
      "stale_days": 1825
    },
    "industry_trade": {
      "fresh_days": 30,
      "stale_days": 365
    },
    "default": {
      "fresh_days": 30,
      "stale_days": 365
    }
  },
  "default_thresholds": {
    "hidden_below": 0.25,
    "strong_caveat_below": 0.45,
    "light_caveat_below": 0.65,
    "fully_cited_above": 0.80
  }
}
