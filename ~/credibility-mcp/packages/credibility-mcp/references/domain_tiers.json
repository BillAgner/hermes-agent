{
  "$schema": "source-credibility v1 tier table",
  "weights": {
    "source_class": 0.30,
    "citation_provenance": 0.20,
    "domain_authority": 0.15,
    "corroboration": 0.15,
    "recency": 0.10,
    "author_track_record": 0.05,
    "methodology": 0.05
  },
  "classes": {
    "primary_data": {
      "score_baseline": 0.90,
      "description": "First-party datasets released by the data owner (CME, BLS, BEA, FRED, EIA, etc.)"
    },
    "peer_reviewed": {
      "score_baseline": 0.88,
      "description": "Peer-reviewed journals, conference proceedings, indexed in PubMed/IEEE/arXiv-with-endorsement"
    },
    "gov_official": {
      "score_baseline": 0.85,
      "description": "Government bodies, central banks, official policy publications"
    },
    "primary_doc": {
      "score_baseline": 0.80,
      "description": "Company filings (10-K/10-Q), official press releases, court records"
    },
    "mainstream_press": {
      "score_baseline": 0.75,
      "description": "Editorial press with standards: Reuters, AP, Bloomberg, WSJ, FT, NYT, BBC, Economist"
    },
    "industry_trade": {
      "score_baseline": 0.65,
      "description": "Industry trade publications (Mining Weekly, Kitco editorial, LBMA)"
    },
    "recognized_expert_blog": {
      "score_baseline": 0.55,
      "description": "Individual analysts with track records, established Substacks, known newsletters"
    },
    "niche_forum": {
      "score_baseline": 0.40,
      "description": "Topic-specific forums (r/Silverbugs, Stack Exchange sites, professional Slack/Discord archives)"
    },
    "generic_blog": {
      "score_baseline": 0.38,
      "description": "Personal blogs, generic Medium posts, WordPress/Blogger/Substack without track record"
    },
    "social_media": {
      "score_baseline": 0.30,
      "description": "Twitter/X, Facebook, Instagram, LinkedIn, TikTok, Threads"
    },
    "content_farm": {
      "score_baseline": 0.15,
      "description": "SEO-driven content farms, AI-spam sites, known low-quality aggregators"
    },
    "unknown": {
      "score_baseline": 0.40,
      "description": "Cannot classify — assigned neutral baseline"
    }
  },
  "domain_to_class": {
    "cmegroup.com": "primary_data",
    "comex.com": "primary_data",
    "bls.gov": "primary_data",
    "bea.gov": "primary_data",
